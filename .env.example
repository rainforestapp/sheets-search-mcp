# Required: Slack bot token (xoxb-...)
SLACK_BOT_TOKEN=

# Required: Slack app-level token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=

# Required: Full URL of the Google Sheet to query
SHEETS_SPREADSHEET_URL=

# Required: API key for your LLM provider
# For Anthropic: set ANTHROPIC_API_KEY
# For OpenAI: set OPENAI_API_KEY
# For other providers: see https://docs.litellm.ai/docs/providers
ANTHROPIC_API_KEY=

# Optional: Model to use (default: anthropic/claude-haiku-4-5-20251001)
# Uses litellm format — prefix with provider name
# Examples:
#   MODEL=anthropic/claude-sonnet-4-6
#   MODEL=openai/gpt-4o
#   MODEL=gemini/gemini-2.0-flash
# MODEL=

# Optional: Bot framing/persona as a string (overrides FRAMING.md file)
# BOT_FRAMING=You are a data assistant for Acme Corp...

# Optional: Path to framing file (default: ./FRAMING.md)
# FRAMING_PATH=

# Optional: Service account JSON string (for cloud deploys instead of service-account.json file)
# GOOGLE_SERVICE_ACCOUNT_JSON=
