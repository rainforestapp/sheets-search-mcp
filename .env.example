# Required: Slack bot token (xoxb-...)
SLACK_BOT_TOKEN=

# Required: Slack app-level token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=

# Required: Anthropic API key
ANTHROPIC_API_KEY=

# Required: Full URL of the Google Sheet to query
SHEETS_SPREADSHEET_URL=

# Optional: Claude model to use (default: claude-haiku-4-5-20251001)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: Bot framing/persona as a string (overrides FRAMING.md file)
# BOT_FRAMING=You are a data assistant for Acme Corp...

# Optional: Path to framing file (default: ./FRAMING.md)
# FRAMING_PATH=

# Optional: Service account JSON string (for cloud deploys instead of service-account.json file)
# GOOGLE_SERVICE_ACCOUNT_JSON=
